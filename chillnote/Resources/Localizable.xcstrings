    "onboarding.demo_note.walk_content": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vielleicht bedeutet Produktivität nicht, mehr zu schaffen. Vielleicht geht es eher darum, sich den ganzen Tag über weniger zerrissen zu fühlen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maybe productivity is not about doing more. Maybe it is about feeling less split all day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tal vez la productividad no sea hacer más, sino sentirse menos fragmentado durante el día."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La productivité, ce n’est peut-être pas faire plus. C’est peut-être se sentir moins dispersé toute la journée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生産性って、もっと多くこなすことじゃないのかもしれない。一日中、気持ちが引き裂かれないでいられることなのかもしれない。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생산성은 더 많이 해내는 게 아니라, 하루 종일 덜 산만하게 느끼는 데 있는지도 모른다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "也许高效不是做得更多，而是别让自己整天被拆得太碎。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "也許高效不是做得更多，而是別讓自己整天被拆得太碎。"
          }
        }
      }
    },
