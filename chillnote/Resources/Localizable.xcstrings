    "recording.onboarding.point.messy.body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Brain Dump funktioniert am besten, wenn du einfach alles aussprichst, was dir durch den Kopf geht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Brain dump works best when you say whatever is on your mind."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El brain dump funciona mejor cuando dices todo lo que te pasa por la cabeza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le brain dump fonctionne mieux quand vous dites simplement tout ce qui vous passe par la tete."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "頭に浮かぶことをそのまま話すほど、ブレインダンプはうまく機能します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "머릿속에 떠오르는 것을 그대로 말할수록 brain dump가 더 잘 작동해요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "想到什么就说什么，brain dump 反而会更有效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "想到什麼就說什麼，brain dump 反而會更有效。"
          }
        }
      }
    },
    "recording.onboarding.point.messy.title": {
      "extractionState": "manual",
      "localizations": {
