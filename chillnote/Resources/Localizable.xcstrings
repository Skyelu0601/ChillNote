    "home.rating_prompt.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn dir ChillNote gefaellt, gib uns gern eine Bewertung. Wenn nicht, sag uns bitte Bescheid."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you like ChillNote, please leave us a rating. If not, we would love to hear from you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si te gusta ChillNote, dejanos una valoracion. Si no, cuentanoslo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous aimez ChillNote, laissez-nous une note. Sinon, dites-le-nous."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "気に入っていただけたら、評価をお願いします。気になる点があれば、ぜひ教えてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote가 마음에 드신다면 평점을 남겨 주세요. 아니라면 어떤 점이 아쉬웠는지 알려 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "喜欢的话给我们评个分，不满意也欢迎告诉我们。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "喜歡的話給我們評個分，不滿意也歡迎告訴我們。"
          }
        }
      }
    },
