    "about.section.2.quote" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Die Produktidee kommt mir, während ich gehe, debugge oder gerade den Kontext wechsle.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"The product thought hits while I am walking, debugging, or switching contexts.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"La idea de producto me llega mientras camino, depuro o cambio de contexto.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"L'idée produit me vient pendant que je marche, que je débogue ou que je change de contexte.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「プロダクトのアイデアは、歩いているときやデバッグ中、あるいは別の作業に切り替えている最中にふと浮かぶ。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"제품 아이디어는 걷는 중이거나, 디버깅 중이거나, 맥락을 전환하는 순간에 불쑥 떠오른다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“产品上的想法，总会在我走路、调试，或者切换任务的时候突然冒出来。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「產品上的想法，總會在我走路、除錯，或切換任務的時候突然冒出來。」"
          }
        }
      }
    },
