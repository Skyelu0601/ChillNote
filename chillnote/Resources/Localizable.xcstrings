    "recording.onboarding.point.organize.body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote hilft dir danach, deine Aufnahme in eine saubere Notiz zu verwandeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote will help turn your recording into a clean note afterward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote te ayudara a convertir tu grabacion en una nota clara despues."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote vous aidera ensuite a transformer votre enregistrement en note claire."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音した内容はあとで ChillNote がすっきりしたノートに整えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음한 내용은 이후에 ChillNote가 정돈된 노트로 정리해 줄게요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "后面 ChillNote 会帮你把这段语音整理成清晰的笔记。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "後面 ChillNote 會幫你把這段語音整理成清晰的筆記。"
          }
        }
      }
    },
