        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续即表示你同意我们的[服务条款](https://www.chillnoteai.com/terms.html)和[隐私政策](https://www.chillnoteai.com/privacy.html)。"
