    "about.section.2.body.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Builders do not just have tasks. They have feature ideas, product tradeoffs, naming thoughts, launch notes, and tiny insights that appear in the middle of everything else."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Builders do not just have tasks. They have feature ideas, product tradeoffs, naming thoughts, launch notes, and tiny insights that appear in the middle of everything else."
