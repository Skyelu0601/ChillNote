            "value" : "\"No necesito solo el video. Necesito la estructura detras.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Je n ai pas seulement besoin de la video. J ai besoin de la structure derriere.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
