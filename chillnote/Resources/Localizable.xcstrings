    "Say anything on your mind, then we will help you turn it into something useful." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sprich einfach aus, was dir gerade durch den Kopf geht. Wir helfen dir dann, etwas Brauchbares daraus zu machen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Say anything on your mind, then we will help you turn it into something useful."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Di lo que tengas en mente. Luego te ayudaremos a convertirlo en algo útil."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dites simplement ce que vous avez en tête. Nous vous aiderons ensuite à le transformer en quelque chose d’utile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今思っていることをそのまま話してみてください。あとで使える形に整えるお手伝いをします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지금 떠오르는 생각을 편하게 말해보세요. 나중에 쓸 수 있는 형태로 정리해드릴게요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把你现在想到的随口说出来就好。接下来我们会帮你把它整理成真正有用的内容。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把你現在想到的隨口說出來就好。接下來我們會幫你把它整理成真正有用的內容。"
          }
        }
      }
    },
    "Search" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
