    "about.section.4.body.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote is based on a simple belief: forcing structure too early kills useful thinking."
