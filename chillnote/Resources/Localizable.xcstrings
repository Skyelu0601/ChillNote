    "recipes.empty.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuge Skills aus der Bibliothek hinzu. Zahlende Mitglieder konnen auch eigene benutzerdefinierte Skills erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add Skills from the library. Creating your own custom actions is available for paid members."
