    "about.section.1.body.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creators rarely get ideas in neat paragraphs. They come as hooks, angles, half-sentences, scenes, titles, and sudden bursts of clarity."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creators rarely get ideas in neat paragraphs. They come as hooks, angles, half-sentences, scenes, titles, and sudden bursts of clarity."
          }
        },
