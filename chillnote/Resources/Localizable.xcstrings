    "subscription.footer.manage_disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwalte oder kündige dein Abo unter Einstellungen > Apple-ID > Abonnements."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage or cancel your subscription in Settings > Apple ID > Subscriptions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona o cancela tu suscripción en Ajustes > Apple ID > Suscripciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez ou annulez votre abonnement dans Réglages > Apple ID > Abonnements."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションの管理・解約は「設定 > Apple ID > サブスクリプション」から行えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 > Apple ID > 구독에서 구독을 관리하거나 취소합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以在“设置 > Apple ID > 订阅”中管理或取消订阅。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以在「設定 > Apple ID > 訂閱項目」中管理或取消訂閱。"
          }
        }
      }
    },
    "subscription.footer.payment_disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Zahlung wird bei Kaufbestätigung deinem Apple-ID-Konto belastet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Payment will be charged to your Apple ID account at confirmation of purchase."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El pago se cargará a tu cuenta de Apple ID al confirmar la compra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le paiement sera facturé sur votre compte Apple ID lors de la confirmation de l'achat."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入確定時に、Apple IDアカウントに請求されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "결제 금액은 구매 확인 시 Apple ID 계정으로 청구됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买确认后，费用将从你的 Apple ID 账户中扣除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "購買確認後，費用將從你的 Apple ID 帳戶扣款。"
          }
        }
      }
    },
    "subscription.footer.renewal_disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Abonnement verlängert sich automatisch, sofern es nicht mindestens 24 Stunden vor Ablauf des aktuellen Zeitraums gekündigt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscription automatically renews unless canceled at least 24 hours before the end of the current period."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La suscripción se renueva automáticamente, salvo que se cancele al menos 24 horas antes de que finalice el período actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'abonnement se renouvelle automatiquement, sauf annulation au moins 24 heures avant la fin de la période en cours."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の期間が終了する24時間以上前に解約しない限り、サブスクリプションは自動更新されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 기간이 종료되기 최소 24시간 전에 구독을 취소하지 않으면 구독이 자동으로 갱신됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "除非你在当前周期结束前至少 24 小时取消，否则订阅会自动续费。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "除非你在目前週期結束前至少 24 小時取消，否則訂閱會自動續訂。"
          }
        }
      }
    },
