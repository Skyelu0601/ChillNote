    "about.intro" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote is built for people who create: content creators, builders, developers, designers, writers, and anyone whose best ideas tend to arrive before they are fully formed. It helps you catch the spark quickly, then shape it into something clear enough to keep building from."
          }
        },
        "en" : {
          "stringUnit" : {
