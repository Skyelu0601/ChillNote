    "about.section.3.quote" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Ich denke am besten, wenn ich laut spreche.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"I do my best thinking out loud.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Pienso mejor cuando hablo en voz alta.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Je réfléchis mieux à voix haute.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「声に出して話しているときが、一番よく考えられる。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"나는 소리 내어 말할 때 가장 잘 생각할 수 있다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“把想法说出来的时候，我最能想清楚。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「把想法說出來的時候，我最能想清楚。」"
          }
        }
      }
    },
