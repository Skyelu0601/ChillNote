    "about.not.quote" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Grenzen setzen, um das Chill zu bewahren.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Defining the boundaries to preserve the 'Chill'.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Poner límites para conservar ese Chill.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Poser des limites pour préserver le Chill. »"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「『チル』を維持するための境界線を定義する。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"'냉기'를 보존하기 위한 경계를 정의합니다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“划清边界，守住那份 Chill。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「劃清界線，守住那份 Chill。」"
          }
        }
      }
    },
