    "paywall.first_voice_success.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast gerade eine echte Sprachnotiz in etwas Nutzbares verwandelt. Mit Pro fühlt sich der ganze Ablauf deutlich flüssiger an, wenn du weitermachen willst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You already made a few real notes. If you want to keep the momentum going, Pro makes recording and polishing feel much smoother."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acabas de convertir una nota de voz real en algo útil. Pro hace que todo el flujo sea más fluido cuando quieres seguir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous venez de transformer une vraie note vocale en quelque chose d’utile. Pro rend tout le flux plus fluide quand vous voulez continuer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今、本当に録った音声メモを使える形にできました。Proなら、この流れ全体をもっとスムーズに続けられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "방금 실제 음성 메모를 바로 쓸 수 있는 결과로 바꿨어요. Pro는 계속 이어갈 때 이 흐름 전체를 더 매끄럽게 만들어줘요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已经连续做出几条真实笔记了。如果你想继续保持这个节奏，升级 Pro 后，录音和整理都会顺很多。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
