    "about.section.2.body.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**The Problem:** Most of those thoughts are too valuable to lose, but too rough to stop and document properly in the moment."
          }
        },
