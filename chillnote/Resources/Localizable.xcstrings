        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "정말로 계정을 삭제하시겠어요? 모든 데이터가 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确定要删除账号吗？你的所有数据将被永久删除，且无法撤销。"
