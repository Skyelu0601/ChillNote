    "Your data is used only to complete your request. We and our third-party partners do not use your notes or recordings to train models." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Daten werden nur verwendet, um deine Anfrage zu bearbeiten. Weder wir noch unsere Drittpartner verwenden deine Notizen oder Aufnahmen zum Trainieren von Modellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data is used only to complete your request. We and our third-party partners do not use your notes or recordings to train models."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus datos solo se usan para completar tu solicitud. Ni nosotros ni nuestros socios externos usamos tus notas o grabaciones para entrenar modelos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos donnees sont utilisees uniquement pour traiter votre demande. Ni nous ni nos partenaires tiers n'utilisons vos notes ou enregistrements pour entrainer des modeles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたのデータは、リクエストの処理にのみ使用されます。私たちおよび第三者パートナーが、あなたのノートや録音をモデルの学習に使用することはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "회원님의 데이터는 요청을 처리하는 데에만 사용됩니다. 당사와 제3자 파트너는 회원님의 노트나 녹음을 모델 학습에 사용하지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的数据仅用于完成你的本次请求。我们和第三方合作伙伴都不会使用你的笔记或录音来训练模型。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的資料僅用於完成你的本次請求。我們與第三方合作夥伴都不會使用你的筆記或錄音來訓練模型。"
          }
        }
      }
