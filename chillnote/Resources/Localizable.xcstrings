    "onboarding.voice_prompt" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich denke gerade über den Content für morgen nach ... ich sollte wahrscheinlich, äh, zuerst das Thema festlegen. Warte, nein, vielleicht sollte ich erst mal mit meinem Team sprechen. Ach, und denk dran, auf dem Heimweg Kaffee mitzunehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I'm thinking about tomorrow's content... I should probably, uh, figure out the topic first. Wait, no, maybe I should talk to my team first. Also, remember to pick up coffee on the way home."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estoy pensando en el contenido de mañana... debería, eh, definir primero el tema. Espera, no, mejor debería hablar primero con mi equipo. Ah, y acuérdate de pasar por café de camino a casa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je pense au contenu de demain... je devrais sans doute, euh, trouver le sujet d’abord. Attends, non, peut-être que je devrais d’abord en parler avec mon équipe. Ah, et pense à prendre du café en rentrant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "明日のコンテンツのことを考えてるんだけど……たぶん、えっと、まずはテーマを決めたほうがいいかな。待って、やっぱり先にチームに相談したほうがいいかも。あと、帰りにコーヒーを買うのも忘れないで。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내일 올릴 콘텐츠 생각 중인데... 아마, 음, 먼저 주제를 정해야 할 것 같아. 잠깐, 아니지, 먼저 팀이랑 얘기해 봐야 할지도. 아, 그리고 집에 가는 길에 커피 사는 것도 잊지 말고."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我在想明天的内容……我可能得先，呃，把主题想清楚。等等，不对，也许我应该先和团队聊聊。还有，回家的路上记得买咖啡。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我在想明天的內容……我可能得先，呃，把主題想清楚。等等，不對，也許我應該先和團隊聊聊。還有，回家的路上記得買咖啡。"
          }
        }
      }
    },
    "Open Settings" : {
