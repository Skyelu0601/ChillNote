    "settings.voice.preferred_help": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine bevorzugte Sprache sorgt für stabilere Ergebnisse in der Hauptsprache und erhält dennoch gemischte Spracheingaben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preferred language improves primary-language stability while preserving mixed-language speech."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El idioma preferido mejora la estabilidad del idioma principal y mantiene el habla en varios idiomas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La langue préférée améliore la stabilité de la langue principale tout en conservant les passages multilingues."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "優先言語を設定すると、主言語の安定性が上がりつつ、混在した言語表現も保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선호하는 언어는 혼합 언어 음성을 유지하면서 기본 언어의 안정성을 향상시킵니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置首选语言后，可提升主要语言识别稳定性，同时保留混合语言表达。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定偏好語言後，可提升主要語言辨識穩定性，同時保留混合語言表達。"
          }
        }
      }
    },
