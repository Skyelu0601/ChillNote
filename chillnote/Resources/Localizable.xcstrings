    "about.section.1.body.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**The Problem:** By the time you open a blank page and try to type cleanly, the energy of the idea is already fading."
          }
        },
