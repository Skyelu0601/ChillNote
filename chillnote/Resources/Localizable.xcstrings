        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「我已經有了火花，現在需要不同角度。」"
          }
        }
      }
    },
    "about.section.3.title" : {
      "extractionState" : "manual",
