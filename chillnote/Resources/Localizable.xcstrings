    "about.not.heavy_workflow.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If capture feels slow, people stop capturing. ChillNote is meant to stay light, fast, and easy to return to, so it supports creative momentum instead of interrupting it."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
