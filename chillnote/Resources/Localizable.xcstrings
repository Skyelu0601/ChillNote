        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "하나만 골라보세요. 지금 추가한 뒤, 방금 녹음한 노트에 바로 실행해보세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
