      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**The Result:** Less time formatting, filing, and rewriting from scratch. More time staying in motion and returning to ideas that still feel usable later."
          }
        },
        "en" : {
          "stringUnit" : {
