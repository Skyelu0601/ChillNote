    "onboarding.ask.note.flow.content" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst in einem Chat Folgefragen stellen und nützliche Antworten als neue Notizen speichern."
          }
        },
        "en" : {
