    "The notes have been merged into a new note. Would you like to delete the original %lld notes?" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Notizen wurden zu einer neuen Notiz zusammengeführt. Möchtest du die ursprünglichen %lld Notizen löschen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The notes have been merged into a new note. Would you like to delete the original %lld notes?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notas se han fusionado en una nueva nota. ¿Quieres eliminar las %lld notas originales?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les notes ont été fusionnées dans une nouvelle note. Souhaitez-vous supprimer les notes %lld d'origine ?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メモは新しいメモに統合されました。元の%lldメモを削除しますか?"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메모가 새 메모로 병합되었습니다. 원본 %lld 메모를 삭제하시겠습니까?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "笔记已合并成一条新笔记。要删除原来的 %lld 条笔记吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "筆記已合併成一則新筆記。要刪除原來的 %lld 則筆記嗎？"
          }
        }
      }
    },
