    "auth.login.legal_markdown": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit dem Fortfahren stimmst du unseren [Nutzungsbedingungen](https://www.chillnoteai.com/terms.html) und unserer [Datenschutzerklärung](https://www.chillnoteai.com/privacy.html) zu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By continuing, you agree to our [Terms](https://www.chillnoteai.com/terms.html) & [Privacy Policy](https://www.chillnoteai.com/privacy.html)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al continuar, aceptas nuestros [Términos](https://www.chillnoteai.com/terms.html) y nuestra [Política de Privacidad](https://www.chillnoteai.com/privacy.html)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En continuant, vous acceptez nos [Conditions](https://www.chillnoteai.com/terms.html) et notre [Politique de confidentialité](https://www.chillnoteai.com/privacy.html)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "続行すると、[利用規約](https://www.chillnoteai.com/terms.html) と [プライバシーポリシー](https://www.chillnoteai.com/privacy.html) に同意したものとみなされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계속 진행하면 당사의 [약관] (https://www.chillnoteai.com/terms.html) 및 [개인 정보 보호 정책] (https://www.chillnoteai.com/privacy.html) 에 동의하는 것으로 간주됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续即表示你同意我们的[服务条款](https://www.chillnoteai.com/terms.html)和[隐私政策](https://www.chillnoteai.com/privacy.html)。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "繼續即表示你同意我們的[服務條款](https://www.chillnoteai.com/terms.html)與[隱私政策](https://www.chillnoteai.com/privacy.html)。"
          }
        }
