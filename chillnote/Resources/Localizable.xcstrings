    "settings.support.user_agreement_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die Nutzung von ChillNote erklärst du dich damit einverstanden, die App verantwortungsvoll zu verwenden, und du verstehst, dass deine Notizen lokal gespeichert und bei bestehender Anmeldung mit der Cloud synchronisiert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By using ChillNote, you agree to use the app responsibly and understand that your notes are stored locally and synced to the cloud when you're signed in."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al usar ChillNote, aceptas utilizar la app de forma responsable y entiendes que tus notas se almacenan localmente y se sincronizan con la nube cuando inicias sesión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En utilisant ChillNote, vous acceptez d'utiliser l'application de manière responsable et comprenez que vos notes sont stockées localement et synchronisées avec le cloud lorsque vous êtes connecté."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote を利用することで、アプリを適切に使用することに同意し、サインイン中はノートが端末内に保存され、クラウドと同期されることを理解したものとみなされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote를 사용함으로써 귀하는 앱을 책임감 있게 사용할 것에 동의하며, 로그인한 경우 메모가 기기에 로컬로 저장되고 클라우드와 동기화된다는 점을 이해합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 ChillNote 即表示你同意以负责任的方式使用本应用，并理解在你登录后，你的笔记会保存在本地并同步到云端。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 ChillNote 即表示你同意以負責任的方式使用本應用，並理解在你登入後，你的筆記會保存在本機並同步到雲端。"
          }
        }
      }
    },
