    "home.alert.ask_hard_limit.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst die KI gleichzeitig zu maximal %lld Notizen befragen. Bitte reduziere deine Auswahl."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can ask AI about up to %lld notes at a time. Please reduce your selection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes preguntar a la IA sobre hasta %lld notas a la vez. Reduce tu selección."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez interroger l'IA sur un maximum de %lld notes à la fois. Réduisez votre sélection."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一度に AI へ質問できるのは最大 %lld 件のノートです。選択数を減らしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한 번에 AI에 질문할 수 있는 노트는 최대 %lld개입니다. 선택 수를 줄여 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一次最多可向 AI 提问 %lld 条笔记，请减少选择数量。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一次最多可向 AI 提問 %lld 則筆記，請減少選擇數量。"
          }
        }
      }
    },
    "home.alert.ask_soft_limit.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast %lld Notizen ausgewählt. Bei vielen Notizen kann die KI langsamer und weniger präzise sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You selected %lld notes. Asking AI with many notes may be slower and less accurate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has seleccionado %lld notas. Con muchas notas, la IA puede ser más lenta y menos precisa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez sélectionné %lld notes. Avec un grand nombre de notes, l'IA peut être plus lente et moins précise."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 件のノートを選択しました。ノート数が多いと、AI の処理が遅くなり精度が下がる場合があります。"
          }
