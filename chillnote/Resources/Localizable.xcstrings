    "onboarding.demo_note.late_night_content": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich möchte darüber schreiben, wie moderne Arbeit Aufmerksamkeit auf kleine, unsichtbare Weise aufzehrt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I want to write something about how modern work drains attention in tiny invisible ways."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quiero escribir algo sobre cómo el trabajo moderno nos va drenando la atención de formas pequeñas e invisibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J’ai envie d’écrire sur la manière dont le travail moderne grignote notre attention par de minuscules mécanismes invisibles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現代の仕事が、見えないほど小さな形で少しずつ注意力を奪っていくことについて書いてみたい。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현대의 일이 얼마나 작고 보이지 않는 방식으로 집중력을 조금씩 갉아먹는지에 대해 써보고 싶다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我想写点东西，讲讲现代工作是怎样用那些细小又看不见的方式，一点点耗掉人的注意力。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我想寫點東西，講講現代工作是怎樣用那些細小又看不見的方式，一點點耗掉人的注意力。"
          }
        }
      }
    },
