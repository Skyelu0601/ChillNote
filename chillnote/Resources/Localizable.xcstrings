    "ChillNote can also..." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote kann auch..."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
