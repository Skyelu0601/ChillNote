    "error.recording.pending.audio_empty": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wurde keine verwertbare Sprache erkannt. Audio wurde unter Pending Records gespeichert. Bitte prüfen und erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No clear speech was detected. Audio was saved to Pending Records. Please review and retry."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se detectó audio de voz claro. El audio se guardó en Registros pendientes. Revísalo y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune voix exploitable n’a été détectée. L’audio a été enregistré dans les enregistrements en attente. Vérifiez puis réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "はっきりした音声を検出できませんでした。音声は保留中の録音に保存されました。確認してから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유효한 음성이 감지되지 않았습니다. 오디오는 보류 중인 레코드에 저장되었습니다. 확인 후 다시 시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未检测到有效语音。音频已保存到待处理录音，请检查后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未偵測到有效語音。音訊已儲存到待處理錄音，請檢查後重試。"
          }
        }
      }
    },
    "error.recording.pending.auth_required": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sitzung abgelaufen. Audio wurde unter Pending Records gespeichert. Bitte erneut anmelden und dann wiederholen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your session expired. Audio was saved to Pending Records. Please sign in again and retry."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La sesión expiró. El audio se guardó en Registros pendientes. Inicia sesión de nuevo y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre session a expiré. L’audio a été enregistré dans les enregistrements en attente. Reconnectez-vous puis réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログインの有効期限が切れました。音声は保留中の録音に保存されました。再ログインしてから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 세션이 만료되었습니다. 오디오는 보류 중인 레코드에 저장되었습니다. 다시 로그인한 뒤 재시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录状态已失效。音频已保存到待处理录音，请重新登录后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登入狀態已失效。音訊已儲存到待處理錄音，請重新登入後重試。"
          }
        }
      }
    },
    "error.recording.pending.local_file": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Aufnahmedatei konnte nicht gelesen werden. Bitte neu aufnehmen und erneut versuchen."
