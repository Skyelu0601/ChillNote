    "settings.voice.auto_help": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Sprache wird aus dem Audio erkannt. Mehrsprachige Spracheingaben bleiben erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Language will be inferred from audio. Mixed-language speech is preserved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El idioma se detectará a partir del audio. Se conservará el uso de varios idiomas en la misma grabación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La langue est détectée à partir de l'audio. Le mélange de langues est conservé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声から言語を自動判定します。複数言語が混ざっていてもそのまま保持します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어는 오디오에서 추론됩니다. 혼합 언어 음성이 보존됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统会根据音频自动判断语言，并保留混合语言表达。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統會依音訊自動判斷語言，並保留混合語言表達。"
          }
        }
      }
    },
