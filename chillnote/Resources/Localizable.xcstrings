    "settings.export.benefit_move_body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Teile oder verschiebe deine Notizen ganz einfach in Apps wie Obsidian und andere Markdown-freundliche Tools."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share or move your notes easily into apps like Obsidian and other Markdown-friendly tools."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte o mueve tus notas fácilmente a apps como Obsidian y otras herramientas compatibles con Markdown."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Partagez ou déplacez facilement vos notes vers des apps comme Obsidian et d'autres outils compatibles Markdown."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Obsidian のようなアプリや、Markdown対応ツールへノートを簡単に共有・移行できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Obsidian 같은 앱이나 다른 Markdown 친화적 도구로 메모를 쉽게 공유하거나 옮길 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以轻松把笔记分享或迁移到 Obsidian 这样的应用，以及其他支持 Markdown 的工具。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以輕鬆把筆記分享或遷移到 Obsidian 這類應用，以及其他支援 Markdown 的工具。"
          }
        }
      }
    },
