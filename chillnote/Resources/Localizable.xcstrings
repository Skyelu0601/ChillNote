    "recording.onboarding.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du musst deine Gedanken vor dem Aufnehmen nicht sortieren. Sprich natuerlich los, ChillNote hilft dir beim Aufraeumen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You do not need to organize your thoughts before recording. Speak naturally, and ChillNote will help clean things up afterward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No necesitas ordenar tus ideas antes de grabar. Habla con naturalidad y ChillNote te ayudara a acomodarlas despues."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas besoin d'organiser vos pensees avant d'enregistrer. Parlez naturellement et ChillNote vous aidera a remettre de l'ordre ensuite."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音する前に考えを整理しなくて大丈夫です。自然に話せば、あとで ChillNote が整えてくれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음 전에 생각을 정리할 필요 없어요. 자연스럽게 말하면 ChillNote가 나중에 정리해 줄게요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "录音前不用先整理想法。自然说出来就好，后面 ChillNote 会帮你收拾成一条清晰的笔记。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錄音前不用先整理想法。自然說出來就好，後面 ChillNote 會幫你收拾成一條清晰的筆記。"
          }
        }
      }
    },
