    "onboarding.ask.note.source.content" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn deine Notizen nicht ausreichen, kann Ask allgemeines Wissen ergänzen und die Quelle klar kennzeichnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If your notes are not enough, Ask can add general knowledge and clearly label the source."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tus notas no son suficientes, Ask puede añadir conocimiento general y etiquetar claramente la fuente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vos notes ne suffisent pas, Ask peut ajouter des connaissances générales et indiquer clairement la source."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ノートだけで足りない場合、Ask は一般知識を補い、情報源を明確に示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "노트 정보가 충분하지 않으면 Ask가 일반 지식을 보완하고 출처를 명확히 표시합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你的笔记信息不够，Ask 可以补充通用知识，并清晰标注来源。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你的筆記資訊不夠，Ask 可以補充通用知識，並清楚標註來源。"
          }
        }
      }
    },
