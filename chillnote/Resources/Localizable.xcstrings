    "about.tagline" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Sammle die Vorlage.\nMach daraus den naechsten Beitrag.\""
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Capture the pattern.\nTurn it into the next post.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Captura el patron.\nConviertelo en tu proxima publicacion.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Capturez le motif.\nTransformez-le en prochain post.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「型をつかまえる。\n次の投稿へ変える。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"패턴을 잡고,\n다음 게시물로 바꾸세요.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“抓住创作套路，\n变成下一条内容。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「抓住創作套路，\n變成下一則內容。」"
          }
        }
      }
    },
    "about.vision.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote soll der Ort sein, an dem Creator Inspiration nicht nur sammeln, sondern nutzbar machen.\n\nNimm auf, was dich anspringt. Verstehe, warum es funktioniert. Verwandle es mit KI in Material, das deine eigene Stimme, deinen eigenen Kanal und deinen naechsten Schritt unterstuetzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote exists to help creators turn inspiration into reusable creative material.\n\nCapture what catches your attention. Understand why it works. Use AI to shape it into material that supports your own voice, your own channel, and your next move."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote existe para ayudar a los creadores a convertir la inspiracion en material creativo reutilizable.\n\nCaptura lo que llama tu atencion. Entiende por que funciona. Usa IA para darle forma hasta que apoye tu propia voz, tu propio canal y tu proximo paso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote existe pour aider les createurs a transformer l inspiration en matiere creative reutilisable.\n\nCapturez ce qui retient votre attention. Comprenez pourquoi cela fonctionne. Utilisez l IA pour le faconner en une matiere qui soutient votre propre voix, votre propre canal et votre prochain geste."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNoteは、クリエイターがインスピレーションを再利用できる創作素材へ変えるためにあります。\n\n気になったものを残し、なぜ機能するのかを理解し、AIで自分の声、自分のチャンネル、次の一手を支える素材へ整えていくための場所です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote는 크리에이터가 영감을 재사용 가능한 창작 재료로 바꿀 수 있도록 존재합니다.\n\n눈길을 끄는 것을 저장하고, 왜 통하는지 이해하고, AI로 나만의 목소리와 채널, 다음 움직임을 돕는 재료로 다듬으세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote 的存在，是为了帮助创作者把灵感变成可复用的创作素材。\n\n先保存那些抓住你注意力的东西，再理解它为什么有效，最后用 AI 把它整理成能支持你的表达、你的频道、你的下一步行动的素材。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote 的存在，是為了幫助創作者把靈感變成可複用的創作素材。\n\n先保存那些抓住你注意力的東西，再理解它為什麼有效，最後用 AI 把它整理成能支持你的表達、你的頻道、你的下一步行動的素材。"
          }
        }
      }
    },
