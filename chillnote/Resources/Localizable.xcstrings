          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al continuar, aceptas nuestros [Términos](https://www.chillnoteai.com/terms.html) y nuestra [Política de Privacidad](https://www.chillnoteai.com/privacy.html)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
