    "Next time, tap the koala icon, select a note, and choose a Skill." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe beim nächsten Mal auf das Koala-Symbol, wähle eine Notiz aus und entscheide dich für einen Skill."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Next time, tap the koala icon, select a note, and choose a Skill."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La próxima vez, toca el icono del koala, selecciona una nota y elige un Skill."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La prochaine fois, touchez l’icône koala, sélectionnez une note et choisissez un Skill."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "次からは、コアラのアイコンをタップしてノートを選び、Skill をひとつ選ぶだけです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다음부터는 코알라 아이콘을 누르고 노트를 선택한 뒤 Skill을 고르면 돼요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下次只要点一下考拉图标，选中一条笔记，再选择一个 Skill 就可以了。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下次只要點一下考拉圖示，選取一條筆記，再選擇一個 Skill 就可以了。"
          }
        }
      }
    },
    "Nice. Now tap the koala icon and select the note you just recorded." : {
      "extractionState" : "stale",
