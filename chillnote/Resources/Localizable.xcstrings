    "note_detail.alert.permanent_delete.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird die Notiz dauerhaft gelöscht. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently delete the note. This action cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente la nota. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera définitivement la note. Cette action ne peut pas être annulée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、メモが完全に削除されます。この操作は元に戻すことができません。"
