          }
        }
      }
    },
    "about.not.quote": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Klare Grenzen halten das Produkt ehrlich.\""
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Defining the boundaries keeps the product honest.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Definir los límites mantiene honesto al producto.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Définir les limites permet au produit de rester honnête.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「境界をはっきりさせることで、プロダクトは誠実でいられる。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"경계를 분명히 해야 제품이 솔직해진다.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“把边界说清楚，产品才会更诚实。”"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「把邊界說清楚，產品才會更誠實。」"
          }
        }
      }
    },
    "about.not.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was ChillNote NICHT ist"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What ChillNote is NOT"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo que NO es ChillNote"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce que ChillNote n'est PAS"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote ではないもの"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote가 아닌 것"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 不适合什么"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 不適合什麼"
          }
        }
      }
    },
    "about.section.1.body.1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die nützlichsten Gedanken kommen selten als saubere Absätze. Sie tauchen als Fragmente, lose Verbindungen, unfertige Sätze und plötzliche Geistesblitze mitten im Alltag auf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Most useful thoughts do not arrive as clean paragraphs. They come as fragments, loose connections, unfinished sentences, and sudden sparks that appear in the middle of everything else."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las ideas más útiles rara vez llegan como párrafos limpios. Suelen aparecer como fragmentos, conexiones sueltas, frases inacabadas y chispazos repentinos en medio de todo lo demás."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les pensées les plus utiles n'arrivent presque jamais sous forme de paragraphes bien rangés. Elles surgissent comme des fragments, des liens encore flous, des phrases inachevées et des éclairs d'idée au milieu de tout le reste."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当に使える考えは、きれいな段落の形でやってくることはほとんどありません。断片や、まだつながりきっていない感覚、言い切れていない文、ふとしたひらめきとして現れます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정말 쓸모 있는 생각은 깔끔한 문단으로 오지 않습니다. 조각난 형태, 느슨한 연결, 끝맺지 못한 문장, 갑작스러운 번뜩임으로 일상 한가운데서 튀어나옵니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "真正有用的想法，很少会以完整清晰的段落出现。它们更常常是碎片、松散的连接、没说完的话，或者生活中突然冒出来的一点火花。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "真正有用的想法，很少會以完整清晰的段落出現。它們更常常是碎片、鬆散的連結、沒說完的話，或是生活中突然冒出來的一點火花。"
          }
        }
      }
    },
    "about.section.1.body.2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Das Problem:** Wenn du einen Gedanken erst perfekt ordnen musst, bevor du ihn speichern kannst, verlierst du wahrscheinlich einen Teil davon."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**The Problem:** If you have to organize the thought perfectly before saving it, there is a good chance you lose part of it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**El Problema:** Si tienes que ordenar la idea perfectamente antes de guardarla, hay muchas posibilidades de que pierdas una parte por el camino."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**Le Problème :** Si vous devez organiser parfaitement une pensée avant de la sauvegarder, vous risquez fort d'en perdre une partie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**課題:** きれいに整理できてから保存しようとすると、その考えの一部はすでにこぼれ落ちてしまうかもしれません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**문제:** 생각을 완벽하게 정리한 뒤에야 저장할 수 있다면, 그 사이에 중요한 일부를 놓칠 가능성이 큽니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**问题：** 如果你非要等到想法整理得很完整才肯记下来，那它很可能已经丢掉了一部分。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**問題：** 如果你非要等到想法整理得很完整才肯記下來，那它很可能已經丟掉了一部分。"
          }
        }
      }
    },
    "about.section.1.body.3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Die Lösung:** ChillNote hilft dir, zuerst die rohe Version festzuhalten, solange sie noch lebendig ist, damit du später auf etwas Echtes zurückkommen kannst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**The Solution:** ChillNote helps you capture the raw version first, while it is still alive, so you have something real to return to later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**La Solución:** ChillNote te ayuda a capturar primero la versión en bruto, mientras todavía está viva, para que luego tengas algo real a lo que volver."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**La Solution :** ChillNote vous aide à capturer d'abord la version brute, pendant qu'elle est encore vivante, afin que vous ayez plus tard quelque chose de réel vers quoi revenir."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**解決策:** ChillNote は、その考えがまだ生きているうちにラフなまま残せるようにし、あとで本当に戻ってこられる土台を作ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**해결책:** ChillNote는 생각이 살아 있을 때 거친 버전 그대로 먼저 붙잡아둘 수 있게 해주고, 나중에 다시 돌아올 수 있는 진짜 바탕을 남겨줍니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**解决办法：** ChillNote 会帮你先把最原始的版本接住，趁它还鲜活的时候留下来，这样你之后就有东西可以真正回头继续用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**解決辦法：** ChillNote 會幫你先把最原始的版本接住，趁它還鮮活的時候留下來，這樣你之後就有東西可以真正回頭繼續用。"
          }
        }
      }
    },
    "about.section.1.quote": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Ideen tauchen in Fragmenten auf. Ich muss sie festhalten, bevor sie verschwinden.“"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ideas show up in fragments. I need to catch them before they vanish.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Las ideas aparecen en fragmentos. Tengo que atraparlas antes de que desaparezcan.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Les idées arrivent par fragments. Il faut que je les attrape avant qu'elles ne disparaissent.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「アイデアは断片のまま現れる。消えてしまう前につかまえないといけない。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"아이디어는 조각처럼 떠오른다. 사라지기 전에 붙잡아야 한다.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“灵感总是零零碎碎地冒出来，我得在它消失前抓住它。”"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「靈感總是零零碎碎地冒出來，我得在它消失前抓住它。」"
          }
        }
      }
    },
    "about.section.1.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gedanken kommen selten fertig an"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thoughts rarely arrive finished"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las ideas rara vez llegan terminadas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les pensées arrivent rarement terminées"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "考えは完成形ではやってこない"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생각은 완성된 채로 오지 않습니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "想法很少会完整出现"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "想法很少會完整出現"
          }
        }
      }
    },
    "about.section.2.body.1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote basiert auf einer einfachen Überzeugung: Struktur sollte nach dem Festhalten kommen, nicht davor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote is based on a simple belief: structure should come after capture, not before it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote parte de una idea sencilla: la estructura debe venir después de capturar, no antes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote repose sur une idée simple : la structure doit venir après la capture, pas avant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote にはシンプルな考え方があります。構造は、記録したあとに来るべきであって、その前ではないということです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote는 아주 단순한 믿음에서 출발합니다. 구조는 기록보다 먼저가 아니라, 기록 다음에 와야 한다는 것입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 背后的想法很简单：结构应该发生在记录之后，而不是之前。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 背後的想法很簡單：結構應該發生在記錄之後，而不是之前。"
          }
        }
      }
    },
    "about.section.2.body.2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Woran wir glauben:** Einen Gedanken festzuhalten sollte sofort und druckfrei sein. Ordnen kann man ihn, sobald die Idee sicher ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**What We Believe:** Getting the thought out should feel immediate and low-pressure. Organization can happen once the idea is safe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**En qué creemos:** Sacar una idea debería sentirse inmediato y sin presión. Ordenarla puede venir después, cuando ya esté a salvo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**Ce que nous croyons :** Sortir une pensée doit être immédiat et sans pression. L'organisation peut venir une fois que l'idée est à l'abri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**私たちの考え:** 考えを外に出すことは、すぐできて、気負わずできるべきです。整理は、アイデアが安全に残ったあとでいいのです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**우리가 믿는 것:** 생각을 꺼내는 일은 즉각적이고 부담 없어야 합니다. 정리는 그 생각이 안전하게 남은 다음에 해도 됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**我们的看法：** 把想法说出来这件事，应该足够即时、足够没有压力。等它被安全留下来之后，再整理也不迟。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**我們的看法：** 把想法說出來這件事，應該足夠即時、足夠沒有壓力。等它被安全留下來之後，再整理也不遲。"
          }
        }
      }
    },
    "about.section.2.body.3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Was das bedeutet:** Du brauchst noch keinen perfekten Satz. Eine raue Sprachnotiz kann trotzdem ein klarer, nützlicher Ausgangspunkt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**What That Means:** You do not need the polished sentence yet. A rough voice note can still become a clear, useful starting point."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**Lo que eso significa:** Todavía no necesitas una frase perfecta. Una nota de voz en bruto también puede convertirse en un punto de partida claro y útil."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**Ce que cela implique :** Vous n'avez pas encore besoin de la phrase parfaite. Une note vocale brute peut déjà devenir un point de départ clair et utile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**それが意味すること:** まだ整った一文である必要はありません。ラフな音声メモでも、十分に明確で役に立つ出発点になれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**이게 뜻하는 것:** 아직 매끈한 문장이 아니어도 괜찮습니다. 거친 음성 메모도 충분히 또렷하고 유용한 출발점이 될 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**这意味着：** 你不需要一上来就说得很漂亮。哪怕是一段粗糙的语音，也可以成为一个清晰、有用的起点。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**這意味著：** 你不需要一開始就說得很漂亮。哪怕是一段粗糙的語音，也可以成為一個清晰、有用的起點。"
          }
        }
      }
    },
    "about.section.2.quote": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Die erste Version einer guten Idee ist meistens chaotisch.\""
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"The first version of a good idea is usually messy.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La primera versión de una buena idea casi siempre es caótica.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La première version d'une bonne idée est presque toujours brouillonne.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「いいアイデアの最初の形は、たいていまだ雑だ。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"좋은 아이디어의 첫 버전은 대개 엉성하다.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“一个好想法的第一版，通常都是乱的。”"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「一個好想法的第一版，通常都是亂的。」"
          }
        }
      }
    },
    "about.section.2.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erst festhalten, dann ordnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture first, organize later"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura primero, organiza después"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Capturer d'abord, organiser ensuite"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず残して、整えるのはあとで"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "먼저 붙잡고, 정리는 나중에"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先记录，再整理"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "先記錄，再整理"
          }
        }
      }
    },
    "about.section.3.body.1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen ist oft zu langsam, wenn der Kopf schnell arbeitet. Sprechen ist häufig der schnellste Weg, mit einem Gedanken Schritt zu halten, während er gerade entsteht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Typing can be too slow when your mind is moving quickly. Speaking is often the fastest way to keep up with a thought while it is happening."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribir puede ser demasiado lento cuando tu mente va deprisa. Hablar suele ser la manera más rápida de seguirle el ritmo a una idea mientras está ocurriendo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Taper peut être trop lent quand l'esprit va vite. Parler est souvent le moyen le plus rapide de suivre une pensée pendant qu'elle se forme."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "頭の回転が速いとき、タイピングでは追いつけないことがあります。考えが生まれている最中に追いつくには、話すことがいちばん速い方法であることがよくあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "머리가 빠르게 돌아갈 때는 타이핑이 너무 느릴 수 있습니다. 생각이 생겨나는 그 순간을 따라잡는 가장 빠른 방법은 종종 말하는 것입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当脑子转得很快时，打字往往太慢了。想要跟上一个正在发生的想法，很多时候开口说出来才是最快的方式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當腦子轉得很快時，打字往往太慢了。想要跟上一個正在發生的想法，很多時候開口說出來才是最快的方式。"
          }
        }
      }
    },
    "about.section.3.body.2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Die Reibung:** In dem Moment, in dem du zu früh anfängst, dich selbst zu editieren, fällt das Momentum ab und der ursprüngliche Gedanke beginnt zu verblassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**The Friction:** The moment you start editing yourself too early, momentum drops and the original thought starts to fade."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**La Fricción:** En cuanto empiezas a editarte demasiado pronto, el impulso baja y la idea original empieza a desvanecerse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**La Friction :** Dès que vous commencez à vous corriger trop tôt, l'élan retombe et la pensée d'origine commence à s'effacer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**つまずき:** 早い段階で自分を編集し始めると、勢いが落ち、もとの考えは薄れ始めます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**마찰:** 너무 이른 순간부터 스스로를 편집하기 시작하면 흐름이 꺾이고, 처음의 생각도 흐려지기 시작합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**阻力：** 你一旦太早开始修改自己，那个流动感就会掉下去，原本的想法也会开始变淡。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**阻力：** 你一旦太早開始修改自己，那個流動感就會掉下去，原本的想法也會開始變淡。"
          }
        }
      }
    },
    "about.section.3.body.3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Die Lösung:** ChillNote lässt dich natürlich sprechen und nutzt dann KI, um den Gedanken zu säubern, zu strukturieren und weiterzutragen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**The Solution:** ChillNote lets you speak naturally, then uses AI to clean up, structure, and carry the thought forward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**La Solución:** ChillNote te deja hablar con naturalidad y luego usa IA para limpiar, estructurar y empujar esa idea hacia adelante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**La Solution :** ChillNote vous laisse parler naturellement, puis utilise l'IA pour clarifier, structurer et faire avancer cette pensée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**解決策:** ChillNote は自然に話せるようにし、そのあと AI で考えを整え、構造化し、先へ進めやすくします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**해결책:** ChillNote는 자연스럽게 말할 수 있게 두고, 그다음 AI로 그 생각을 정리하고 구조화해 다음 단계로 이어지게 합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**解决办法：** ChillNote 让你先自然地说，再用 AI 帮你把这个想法清理出来、整理结构，并继续往前推进。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**解決辦法：** ChillNote 讓你先自然地說，再用 AI 幫你把這個想法清理出來、整理結構，並繼續往前推進。"
          }
        }
      }
    },
    "about.section.3.quote": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Meine Gedanken sind schneller als meine Finger.\""
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"My thoughts run faster than my fingers.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mis pensamientos van más rápido que mis dedos.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mes pensées vont plus vite que mes doigts.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「考える速さに、指が追いつかない。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"내 생각은 손가락보다 더 빨리 달린다.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“我的想法，总是比手指更快。”"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「我的想法，總是比手指更快。」"
          }
        }
      }
    },
    "about.section.3.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprechen hilft, den Gedanken zu halten"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talking helps you keep the thought"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hablar te ayuda a no perder la idea"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parler aide à garder la pensée"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "話すことが、考えをつなぎとめる"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "말하면 생각을 붙잡기 쉬워집니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "说出来，更容易留住想法"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "說出來，更容易留住想法"
          }
        }
      }
    },
    "about.section.4.body.1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Braindump ist nicht das Endergebnis. Es ist das Rohmaterial."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A brain dump is not the end result. It is the raw material."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una descarga mental no es el resultado final. Es la materia prima."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sortir ses idées n'est pas le résultat final. C'est la matière première."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブレインダンプは完成形ではありません。あくまで素材です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생각 정리는 최종 결과물이 아닙니다. 그것은 원재료입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清空大脑并不是最终结果，它只是原始素材。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清空大腦並不是最終結果，它只是原始素材。"
          }
        }
      }
    },
    "about.section.4.body.2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Was danach passiert:** Sobald der Gedanke festgehalten ist, hilft dir ChillNote, ihn zu verfeinern, umzuformen, mit ihm zu sprechen und daraus etwas zu machen, das du wirklich nutzen kannst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**What Happens Next:** Once the thought is captured, ChillNote helps you refine it, reshape it, talk to it, and turn it into something you can actually use."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**Lo que pasa después:** Una vez capturada la idea, ChillNote te ayuda a refinarla, darle otra forma, conversar con ella y convertirla en algo que realmente puedas usar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**Ce qui se passe ensuite :** Une fois la pensée capturée, ChillNote vous aide à l'affiner, la transformer, dialoguer avec elle et en faire quelque chose que vous pouvez réellement utiliser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**そのあとに起きること:** 考えを残したあと、ChillNote はそれを磨き直し、形を変え、対話し、本当に使えるものへと変えていく手助けをします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**그다음에 일어나는 일:** 생각이 붙잡히고 나면 ChillNote는 그것을 다듬고, 다시 빚고, 대화하고, 실제로 쓸 수 있는 형태로 바꾸는 일을 도와줍니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**接下来会发生什么：** 一旦想法被记下来，ChillNote 就会帮你继续润色、重组、对话，并把它变成你真的能用起来的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**接下來會發生什麼：** 一旦想法被記下來，ChillNote 就會幫你繼續潤色、重組、對話，並把它變成你真的能用起來的內容。"
          }
        }
      }
    },
    "about.section.4.body.3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Das Ergebnis:** Weniger Zeit damit, alles neu zu schreiben. Mehr Zeit, mit Ideen weiterzugehen, die später immer noch Sinn ergeben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**The Result:** Less time rewriting from scratch. More time moving forward with ideas that still make sense later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**El Resultado:** Menos tiempo reescribiendo desde cero. Más tiempo avanzando con ideas que siguen teniendo sentido después."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**Le Résultat :** Moins de temps à tout réécrire depuis zéro. Plus de temps à avancer avec des idées qui ont encore du sens plus tard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**結果:** ゼロから書き直す時間は減り、あとから読み返しても意味を保っているアイデアを前に進める時間が増えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**결과:** 처음부터 다시 쓰는 시간은 줄고, 나중에도 여전히 의미가 남아 있는 생각을 밀고 나가는 시간은 늘어납니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**结果：** 你不需要总是从头重写，而是可以把更多时间花在继续推进那些之后依然说得通的想法上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**結果：** 你不需要總是從頭重寫，而是可以把更多時間花在繼續推進那些之後依然說得通的想法上。"
          }
        }
      }
    },
    "about.section.4.quote": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ich habe die Idee, aber mir fehlen die Worte.\""
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"I have the idea, but I can't find the words.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Tengo la idea, pero no encuentro las palabras.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"J'ai l'idée, mais je n'arrive pas à trouver les mots.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「アイデアはあるのに、うまく言葉にできない。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"아이디어는 있는데, 딱 맞는 말이 안 나온다.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“想法有了，但就是还说不清。”"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「想法有了，但就是還說不清。」"
          }
        }
      }
    },
    "about.section.4.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vom Braindump zu etwas Nutzbarem"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From brain dump to something usable"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De descarga mental a algo útil"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des idées brutes à quelque chose d'utile"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブレインダンプを使える形へ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생각 정리에서 쓸 수 있는 결과물로"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从清空大脑，到真正能用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從清空大腦，到真正能用"
          }
        }
      }
    },
    "about.section.5.body.1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote will kein weiterer schwerer Workspace sein, der ständiges Sortieren, Taggen und Pflegen verlangt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote is not trying to become a heavy workspace that demands constant sorting, tagging, and upkeep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote no intenta convertirse en otro espacio de trabajo pesado que exija ordenar, etiquetar y mantener todo constantemente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote n'essaie pas de devenir un espace de travail lourd qui exige de trier, étiqueter et entretenir sans cesse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote が目指しているのは、分類やタグ付け、手入れを常に求める重たいワークスペースになることではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote는 끊임없이 정리하고 태그를 붙이고 관리해야 하는 무거운 작업 공간이 되려는 것이 아닙니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 并不想变成另一个需要你不断分类、打标签、维护的笨重工作台。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 並不想變成另一個需要你不斷分類、加標籤、維護的笨重工作台。"
          }
        }
      }
    },
    "about.section.5.body.2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Das Ziel:** Die Reibung zwischen einer Idee und dem Bewahren dieser Idee verringern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**The Goal:** Reduce the friction between having an idea and keeping it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**El objetivo:** Reducir la fricción entre tener una idea y conseguir conservarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**L’objectif :** Réduire la friction entre le fait d’avoir une idée et le fait de la garder."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**目標：** アイデアが生まれることと、それをちゃんと残せることのあいだにある摩擦を減らすこと。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**목표:** 아이디어가 떠오르는 것과 그것을 붙잡아 두는 것 사이의 마찰을 줄이는 것."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**目标：** 减少“想到一个点子”与“把它留下来”之间的摩擦。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**目標：** 減少「想到一個點子」與「把它留下來」之間的摩擦。"
          }
        }
      }
    },
    "about.section.5.body.3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "**Das Ergebnis:** Du bleibst in Bewegung. Deine Ideen bleiben zugänglich. Und deine Notizen bleiben flexibel genug, um sie bei Bedarf auch anderswo zu nutzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**The Result:** You stay in motion. Your ideas stay accessible. And your notes stay flexible enough to use elsewhere when you need them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "**El Resultado:** Sigues avanzando. Tus ideas siguen accesibles. Y tus notas siguen siendo lo bastante flexibles como para usarlas en otros sitios cuando lo necesites."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "**Le Résultat :** Vous restez en mouvement. Vos idées restent accessibles. Et vos notes restent assez souples pour être réutilisées ailleurs quand vous en avez besoin."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**結果:** 流れを止めずに進み続けられます。アイデアはすぐ手の届く場所に残ります。そしてノートは、必要になれば他の場所でも使えるだけの柔軟さを保ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**결과:** 흐름을 유지한 채 앞으로 나아갈 수 있습니다. 아이디어는 계속 손이 닿는 곳에 남습니다. 그리고 노트는 필요할 때 다른 곳에서도 쓸 수 있을 만큼 유연하게 남습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**结果：** 你可以继续往前走，想法也依然随时可回来看。而你的笔记，也会保持足够灵活，方便你在需要时带到别处继续用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "**結果：** 你可以繼續往前走，想法也依然隨時可回來看。而你的筆記，也會保持足夠靈活，方便你在需要時帶到別處繼續用。"
          }
        }
      }
    },
    "about.section.5.quote": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Ich will weiter etwas schaffen, nicht ein System babysitten.“"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"I want to keep making, not babysit a system.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Quiero seguir creando, no estar pendiente de un sistema todo el tiempo.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Je veux continuer à créer, pas passer mon temps à surveiller un système.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「作り続けたいのであって、システムの面倒を見たいわけじゃない。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"나는 시스템을 계속 돌보는 게 아니라, 계속 만들고 싶다.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“我想一直创作，不想天天伺候一个系统。”"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「我想一直創作，不想天天伺候一個系統。」"
          }
        }
      }
    },
    "about.section.5.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Werkzeug für Momentum, nicht für Pflegeaufwand"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Tool for Momentum, Not Maintenance"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una herramienta para mantener el impulso, no para añadir mantenimiento"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un outil pour garder l’élan, pas pour ajouter de la maintenance"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "維持ではなく、勢いのためのツール"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유지보수가 아니라 추진력을 위한 도구"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务势能，而非增加维护"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "服務動能，而非增加維護"
          }
        }
      }
    },
    "about.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Ort für Gedanken, bevor sie verloren gehen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A place for thoughts before they slip away"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un lugar para tus ideas antes de que se escapen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un endroit pour vos idées avant qu'elles ne s'échappent"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイデアがこぼれ落ちる前の居場所"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생각이 흩어지기 전에 붙잡아둘 곳"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在想法溜走前，先接住它们的地方"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在想法溜走前，先接住它們的地方"
          }
        }
      }
    },
    "about.tagline": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Erst raus damit.\nDann in Form bringen.\""
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Brain dump first.\nShape it later.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Sácalo primero.\nDale forma después.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Sortez-le d'abord.\nDonnez-lui une forme ensuite.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「まずはブレインダンプ。\n整えるのはあとで。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"먼저 쏟아내고,\n나중에 다듬으세요.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“先把想法说出来，\n再慢慢整理。”"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「先把想法說出來，\n再慢慢整理。」"
          }
        }
      }
    },
    "about.vision.body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote ist da, damit sich ein Braindump leicht, schnell und lohnend anfühlt.\n\nEs hilft dir, Gedanken festzuhalten, solange sie noch lebendig sind, und sie dann in etwas Klares, Nützliches und Wiederverwendbares zu formen, wenn du bereit bist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote exists to make brain dumping feel easy, fast, and worth returning to.\n\nIt helps you get thoughts out while they are still alive, then shape them into something clear, useful, and reusable when you are ready."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote existe para que la descarga mental se sienta fácil, rápida y valga la pena repetirla.\n\nTe ayuda a sacar tus pensamientos mientras todavía están vivos y luego a convertirlos en algo claro, útil y reutilizable cuando estés listo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote existe pour que vider sa tête soit simple, rapide et donne envie d'y revenir.\n\nIl vous aide à sortir vos pensées tant qu'elles sont encore vivantes, puis à les transformer en quelque chose de clair, utile et réutilisable quand vous êtes prêt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote は、ブレインダンプを気軽に、素早く、また戻ってきたくなるものにするためにあります。\n\nまだ生きている考えをまず外に出し、準備ができたときに、それを明確で役に立ち、再利用できる形へ整える手助けをします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote는 생각 정리가 쉽고, 빠르고, 다시 돌아오고 싶은 일이 되도록 존재합니다.\n\n아직 살아 있는 생각을 먼저 꺼내고, 준비가 되었을 때 그것을 또렷하고 유용하며 다시 활용할 수 있는 형태로 다듬도록 도와줍니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 的存在，是为了让“清空大脑”这件事变得轻松、快速，而且值得你一再回来使用。\n\n它帮助你在想法还鲜活的时候先把它说出来，等你准备好了，再把它整理成清晰、有用、还能反复利用的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 的存在，是為了讓「清空大腦」這件事變得輕鬆、快速，而且值得你一再回來使用。\n\n它幫助你在想法還鮮活的時候先把它說出來，等你準備好了，再把它整理成清晰、有用、還能反覆利用的內容。"
          }
        }
      }
    },
    "about.vision.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unsere Vision"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Our Vision"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nuestra Visión"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Notre vision"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "私たちのビジョン"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "우리의 비전"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们的愿景"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我們的願景"
          }
        }
      }
    },
    "agent_recipe.brainstorm.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entwickle verschiedene Blickwinkel, um einen Gedanken weiter auszubauen."
          }
