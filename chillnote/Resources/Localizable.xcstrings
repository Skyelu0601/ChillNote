    "\"I have the idea, but I can't find the words.\"" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Ich habe die Idee, aber mir fehlen die Worte.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"I have the idea, but I can't find the words.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Tengo la idea, pero no encuentro las palabras.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"J'ai l'idée, mais je ne trouve pas les mots.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「アイデアはあるけど、言葉が見つからない。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"아이디어는 있지만 단어를 찾을 수 없습니다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“我有想法，却不知道该怎么说出来。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「我有想法，卻不知道該怎麼說出來。」"
          }
        }
      }
    },
    "\"Life is too short to adjust margins.\"" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Das Leben ist zu kurz, um an Rändern herumzuschieben.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Life is too short to adjust margins.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"La vida es demasiado corta para ajustar los márgenes\"."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"La vie est trop courte pour ajuster les marges.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「マージンを調整するには人生は短すぎる。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"여백을 조정하기에는 인생이 너무 짧습니다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“人生苦短，别把时间花在调页边距上。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「人生苦短，別把時間花在調頁邊距上。」"
          }
        }
      }
    },
    "\"My thoughts run faster than my fingers.\"" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Meine Gedanken laufen schneller als meine Finger.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"My thoughts run faster than my fingers.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mis pensamientos corren más rápido que mis dedos.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mes pensées courent plus vite que mes doigts.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「私の思考は指よりも速く動きます。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"내 생각은 손가락보다 빠르게 움직인다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“我的思绪跑得比我的手指还快。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“我的思緒跑得比我的手指還快。”"
          }
        }
      }
    },
    "\"Talk helps untangle thoughts.\"" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Reden hilft, Gedanken zu entwirren.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Talk helps untangle thoughts.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Hablar ayuda a desenredar los pensamientos\"."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Parler aide à démêler les pensées.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「話すことは考えを解きほぐすのに役立ちます。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"대화는 생각을 푸는 데 도움이 됩니다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“谈话有助于理清思绪。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“談話有助於理清思緒。”"
          }
        }
      }
    },
    "\"Typing is unnatural; Speaking is instinct.\"" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Tippen ist unnatürlich; Sprechen ist Instinkt.“"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Typing is unnatural; Speaking is instinct.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Escribir no es natural; hablar es instinto\"."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Taper n'est pas naturel ; parler est un instinct.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「タイピングは不自然だが、話すのは本能だ。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"타이핑은 부자연스럽고 말하는 것은 본능이다.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“打字是不自然的；说话是本能。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“打字是不自然的；說話是本能。”"
          }
        }
      }
    },
