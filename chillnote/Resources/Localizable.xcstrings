    "about.workflow.ai.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lass KI Transkripte bereinigen, Hooks erkennen, Notizen ordnen und aus Rohmaterial klare Ansaetze machen."
          }
        },
        "en" : {
          "stringUnit" : {
