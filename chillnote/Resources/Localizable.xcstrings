      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die lokalen Daten konnten nicht initialisiert werden. Bitte versuch es erneut. Wenn das Problem bleibt, starte die App neu oder gib etwas Gerätespeicher frei und probier es dann noch einmal."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Local data initialization failed. Please try again. If it still fails, restart the app or free up device storage and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Error al inicializar los datos locales. Inténtalo de nuevo. Si sigue fallando, reinicia la app o libera espacio en tu dispositivo y vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'initialisation des données locales a échoué. Veuillez réessayer. Si l'échec persiste, redémarrez l'application ou libérez l'espace de stockage de l'appareil et réessayez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカルデータの初期化に失敗しました。もう一度試してください。それでも失敗する場合は、アプリを再起動するか、デバイスのストレージを解放して、もう一度試してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "로컬 데이터 초기화에 실패했습니다. 다시 시도해 주세요. 그래도 실패하면 앱을 다시 시작하거나 기기 저장 공간을 확보한 후 다시 시도하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本地数据初始化失败。请再试一次。如果仍然失败，请重新启动应用程序或释放设备存储空间，然后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本地資料初始化失敗。請再試一次。如果仍然失敗，請重新啟動應用程式或釋放裝置儲存空間，然後重試。"
