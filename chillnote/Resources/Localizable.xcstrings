        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres eliminar tu cuenta? Todos tus datos se borrarán de forma permanente. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voulez-vous vraiment supprimer votre compte ? Toutes vos données seront supprimées définitivement. Cette action est irréversible."
