    "onboarding.flow.page2.callout" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Sprich es einfach aus.\nWir kümmern uns um den Rest.\""
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Talk it out.\nWe'll take care of the rest.\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Solo dilo.\nNosotros nos encargamos del resto.\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Dites-le simplement.\nOn s'occupe du reste.\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「話すだけでいい。\nあとは私たちに任せて。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"그냥 말해보세요.\n나머지는 우리가 맡을게요.\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“你只管说出来。\n剩下的交给我们。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「你只管說出來。\n剩下的交給我們。」"
          }
        }
      }
    },
