    "recording.onboarding.point.speak.body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du musst vorher keine Struktur oder Logik sortieren. Sprich einfach los."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You do not need to organize structure or logic first. Just start talking."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No necesitas ordenar la estructura ni la logica primero. Solo empieza a hablar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas besoin d'organiser la structure ou la logique d'abord. Commencez simplement a parler."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初に構成や論理を考えなくて大丈夫です。そのまま話し始めてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "먼저 구조나 논리를 정리할 필요 없어요. 그냥 말하기 시작하면 돼요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不用先想结构，也不用先理顺逻辑，直接开口说就行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不用先想結構，也不用先理順邏輯，直接開口說就行。"
          }
        }
      }
    },
    "recording.onboarding.point.speak.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einfach sprechen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Just talk"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo habla"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parlez simplement"
          }
        },
        "ja": {
          "stringUnit": {
