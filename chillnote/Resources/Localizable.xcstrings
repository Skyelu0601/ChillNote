    "about.section.4.body.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**What We Believe:** Capture should feel immediate and forgiving. Organization should happen after the thought is safe."
