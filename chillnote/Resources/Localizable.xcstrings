    "error.recording.pending.network": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Netzwerkproblem erkannt. Audio wurde unter Pending Records gespeichert. Bitte bei stabiler Verbindung erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network issue detected. Audio was saved to Pending Records. Please retry when your connection is stable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se detectó un problema de red. El audio se guardó en Registros pendientes. Inténtalo de nuevo con una conexión estable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un problème réseau a été détecté. L’audio a été enregistré dans les enregistrements en attente. Réessayez quand la connexion est stable."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークに問題があります。音声は保留中の録音に保存されました。接続が安定してから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크 문제가 감지되었습니다. 오디오는 보류 중인 레코드에 저장되었습니다. 연결이 안정되면 다시 시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络异常，暂时无法转录。音频已保存到待处理录音，请在网络稳定后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "網路異常，暫時無法轉錄。音訊已儲存到待處理錄音，請在網路穩定後重試。"
          }
        }
