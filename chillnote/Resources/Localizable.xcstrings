          }
        }
      }
    },
    "about.not.meetings.body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote ist nicht als vollständiges System für Meeting-Transkription gedacht. Es ist besser für persönliches Denken, schnelles Festhalten von Ideen und rohe Sprachnotizen, die du später weiterformen willst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote is not designed to be a full meeting transcription system. It is better for personal thinking, fast idea capture, and rough voice notes you want to shape later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote no está diseñado para ser un sistema completo de transcripción de reuniones. Funciona mejor para pensar en voz alta, capturar ideas rápido y guardar notas de voz en bruto que luego quieras dar forma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote n'est pas conçu pour être un système complet de transcription de réunions. Il convient mieux à la réflexion personnelle, à la capture rapide d'idées et aux notes vocales brutes que vous voulez retravailler plus tard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote は会議を丸ごと文字起こしするためのツールではありません。個人的な思考、すばやいアイデアの記録、あとで整えたいラフな音声メモに向いています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote는 회의를 통째로 받아 적는 전사 도구가 아닙니다. 개인적인 생각, 빠른 아이디어 기록, 나중에 다듬고 싶은 거친 음성 메모에 더 잘 어울립니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 不是一个完整的会议转录工具。它更适合个人思考、快速记录灵感，以及那些你之后还想继续整理的粗糙语音。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ChillNote 不是一個完整的會議轉錄工具。它更適合個人思考、快速記錄靈感，以及那些你之後還想繼續整理的粗糙語音。"
          }
        }
      }
    },
