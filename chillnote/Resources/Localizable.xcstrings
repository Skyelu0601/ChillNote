    "about.not.long_form.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillNote is for the seed, not the whole tree. It helps you catch the raw material for a post, product, script, essay, or concept before you move into full drafting elsewhere."
          }
        },
