    "error.recording.pending.quota_reached": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tägliches Sprachlimit erreicht. Audio wurde unter Pending Records gespeichert. Upgrade durchführen oder morgen erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Daily voice limit reached. Audio was saved to Pending Records. Upgrade or retry tomorrow."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se alcanzó el límite diario de voz. El audio se guardó en Registros pendientes. Actualiza o vuelve a intentarlo mañana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La limite vocale quotidienne est atteinte. L’audio a été enregistré dans les enregistrements en attente. Mettez à niveau ou réessayez demain."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本日の音声上限に達しました。音声は保留中の録音に保存されました。アップグレードするか、明日もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일일 음성 한도에 도달했습니다. 오디오는 보류 중인 레코드에 저장되었습니다. 업그레이드하거나 내일 다시 시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今日语音额度已用完。音频已保存到待处理录音，升级后可继续，或明天再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "今日語音額度已用完。音訊已儲存到待處理錄音，升級後可繼續，或明天再試。"
          }
        }
      }
    },
    "error.recording.pending.service_configuration": {
