        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega Skills desde la biblioteca. Los miembros de pago tambien pueden crear sus propios Skills personalizados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des Skills depuis la bibliotheque. Les membres payants peuvent aussi creer leurs propres Skills personnalises."
