    "recording.ghost_prompt.item_1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprich einfach. Es muss nicht ordentlich klingen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Just talk. No need to make it neat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo habla. No hace falta que suene ordenado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parlez simplement. Pas besoin que ce soit bien range."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのまま話して大丈夫。きれいにまとめなくていいです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "그냥 편하게 말해도 돼요. 깔끔하게 정리하지 않아도 돼요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接说就好，不用刻意说得很工整。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "直接說就好，不用刻意說得很工整。"
          }
        }
      }
    },
    "recording.ghost_prompt.item_2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sag als Erstes das, was dir gerade in den Sinn kommt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Say the first thing that comes to mind."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Di lo primero que se te venga a la mente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dites la premiere chose qui vous vient a l'esprit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初に思い浮かんだことから話してみてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제일 먼저 떠오르는 것부터 말해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先说脑子里第一个冒出来的东西。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "先說腦子裡第一個冒出來的東西。"
          }
        }
      }
    },
    "recording.ghost_prompt.item_3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaotische Gedanken sind hier willkommen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Messy thoughts are welcome here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los pensamientos desordenados tambien son bienvenidos aqui."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les pensees en vrac sont les bienvenues ici."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まとまっていない考えでも、ここでは歓迎です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "엉킨 생각이어도 여기서는 괜찮아요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "乱糟糟的想法，在这里也很欢迎。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "亂糟糟的想法，在這裡也很歡迎。"
          }
        }
      }
    },
    "recording.ghost_prompt.item_4": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fang damit an, wie du dich heute fuehlst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start with how you're feeling today."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza por como te sientes hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez par dire comment vous vous sentez aujourd'hui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日の気分から話し始めてみてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 기분이 어떤지부터 말해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可以先从你今天的状态开始说。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可以先從你今天的狀態開始說。"
          }
        }
      }
    },
    "recording.ghost_prompt.item_5": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du musst noch keinen klaren Punkt haben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't need a clear point yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todavia no necesitas tener una idea clara."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez pas encore besoin d'avoir une idee claire."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ要点がはっきりしていなくても大丈夫です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 뚜렷한 요점이 없어도 괜찮아요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你现在还不需要有一个清楚的重点。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你現在還不需要有一個清楚的重點。"
          }
        }
      }
    },
    "recording.ghost_prompt.item_6": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fang ruhig chaotisch an. Wir sortieren es spaeter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start messy. We'll sort it out later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza en desorden. Luego lo acomodamos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez dans le desordre. On triera ca plus tard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "散らかったままで始めて大丈夫。整理はあとでできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "엉켜 있어도 괜찮아요. 정리는 나중에 하면 돼요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先乱着说也没关系，后面我们再一起理顺。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "先亂著說也沒關係，後面我們再一起理順。"
          }
        }
      }
    },
