    "ai_consent.raw_audio" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Roh-Audio wird nur kurzzeitig verarbeitet und nach der Verarbeitung nicht auf unseren Servern gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raw audio is processed ephemerally and is not retained on our servers after processing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El audio sin procesar se trata de forma temporal y no se conserva en nuestros servidores despues del procesamiento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'audio brut est traite de facon ephemere et n'est pas conserve sur nos serveurs apres le traitement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生の音声データは一時的に処理され、処理後に当社のサーバーへ保持されることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "원본 오디오는 일시적으로만 처리되며, 처리 후 당사 서버에 보관되지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "原始音频仅作即时处理，处理完成后不会保留在我们的服务器上。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "原始音訊僅作即時處理，處理完成後不會保留在我們的伺服器上。"
          }
        }
      }
    },
    "ai_consent.trigger.audio_summary" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um deine Sprachnotiz zu transkribieren, kann ChillNote deine Audiodaten und notwendige technische Details zur Verarbeitung an die sicheren Server von ChillNote und an Google Gemini senden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To transcribe your voice note, ChillNote may send your audio and essential technical details to ChillNote's secure server and to Google Gemini for processing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para transcribir tu nota de voz, ChillNote puede enviar tu audio y los detalles tecnicos esenciales a los servidores seguros de ChillNote y a Google Gemini para su procesamiento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour transcrire votre note vocale, ChillNote peut envoyer votre audio et les details techniques essentiels au serveur securise de ChillNote et a Google Gemini pour traitement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声メモを文字起こしするために、ChillNote は音声データと必要な技術情報を、処理のために ChillNote の安全なサーバーおよび Google Gemini に送信する場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "음성 메모를 텍스트로 변환하기 위해 ChillNote는 회원님의 오디오와 필수 기술 정보를 처리 목적으로 ChillNote의 보안 서버와 Google Gemini로 전송할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为了转写你的语音笔记，ChillNote 可能会将你的音频和必要的技术信息发送到 ChillNote 的安全服务器和 Google Gemini 进行处理。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為了轉寫你的語音筆記，ChillNote 可能會將你的音訊和必要的技術資訊傳送到 ChillNote 的安全伺服器和 Google Gemini 進行處理。"
          }
        }
      }
    },
    "ai_consent.trigger.text_summary" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um deine Notiz zu verbessern, kann ChillNote den von dir ausgewaehlten Text zur Verarbeitung an die sicheren Server von ChillNote und an Google Gemini senden."
          }
        },
        "en" : {
