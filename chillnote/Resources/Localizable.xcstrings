    "settings.alert.delete_account.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchtest du dein Konto wirklich löschen? Alle deine Daten werden dauerhaft entfernt. Das kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete your account? All your data will be permanently removed. This action cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar tu cuenta? Todos tus datos se borrarán de forma permanente. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer votre compte ? Toutes vos données seront supprimées définitivement. Cette action est irréversible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当にアカウントを削除しますか？すべてのデータが完全に削除され、この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정말로 계정을 삭제하시겠어요? 모든 데이터가 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除账号吗？你的所有数据将被永久删除，且无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除帳號嗎？你的所有資料將被永久刪除，且無法復原。"
          }
        }
      }
    },
